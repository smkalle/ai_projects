# Optional runtime settings
# Keep uv virtualenv outside mounted project folders that block symlinks.
UV_PROJECT_ENVIRONMENT=$HOME/.venvs/gpt55-notebook-tutorial

# Notebook runner options
NOTEBOOK=gpt55_improvements_documented_python_notebook_tutorial.ipynb
OUTPUT_FORMAT=notebook
TIMEOUT=600

# CLI options (used by run.sh)
# RUN_MODE=notebook|cli|all
# CLI_ARGS=improvements --pattern tool