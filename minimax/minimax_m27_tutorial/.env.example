# .env.example — MiniMax M2.7 Tutorial Suite
# Copy to .env and fill in your values.
# Get your API key at: https://platform.minimax.io

# ── Endpoint ────────────────────────────────────────────────────────────────
# International (default):
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# China users — uncomment and use this instead:
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# ── Auth ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_minimax_api_key_here

# ── Model variant ─────────────────────────────────────────────────────────────
# false = MiniMax-M2.7          (default, balanced)
# true  = MiniMax-M2.7-highspeed (same quality, higher TPS)
MINIMAX_USE_HIGHSPEED=false
