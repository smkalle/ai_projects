# .env.example — Code Eval Workbench
# Copy to .env and fill in your values.

# ── Backend: Anthropic Claude (default) ──────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Backend: MiniMax M2.7 override ───────────────────────────────────────────
# To run the workbench against MiniMax M2.7 instead of Claude:
#
#   1. Get a MiniMax API key at: https://platform.minimax.io
#   2. Replace ANTHROPIC_API_KEY value with your MiniMax key
#   3. Uncomment ANTHROPIC_BASE_URL below (international) or the China line
#
# The Anthropic SDK routes all calls through the MiniMax Anthropic-compatible
# endpoint automatically — no other code changes needed.
#
# International endpoint:
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
#
# China endpoint:
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
#
# Model variant (only applies when using MiniMax base URL):
#   false → MiniMax-M2.7           (default, balanced)
#   true  → MiniMax-M2.7-highspeed (same quality, higher TPS)
# MINIMAX_USE_HIGHSPEED=false
#
# Explicit model name override (overrides auto-detection entirely):
# MODEL_OVERRIDE=MiniMax-M2.7
